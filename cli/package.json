{
  "name": "arkora-cli",
  "version": "1.0.0",
  "description": "CLI for Arkora - the provably human message board",
  "type": "module",
  "bin": {
    "arkora": "./bin/arkora"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@worldcoin/idkit": "^4.0.10",
    "@worldcoin/idkit-core": "^4.0.15",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
